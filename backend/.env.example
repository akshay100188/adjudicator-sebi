# Adjudicator (SEBI) — copy to .env and fill in.

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# Postgres direct connection (psycopg2). Format:
# postgresql://USER:PASSWORD@HOST:PORT/postgres
DATABASE_URL=

# Isolated Postgres schema this app owns. All tables prefixed adj_.
DB_SCHEMA=adjudicator

# LLM keys (Phase 2 onward)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

ENVIRONMENT=development

# Production (Railway): comma-separated allowed CORS origins (your Vercel URL), or "*"
# CORS_ORIGINS=https://your-app.vercel.app
